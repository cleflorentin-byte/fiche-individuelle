# URL et clé publique (anon) de ton projet Supabase
# Disponibles dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# Clé API Anthropic (console.anthropic.com), nécessaire uniquement
# pour la fonctionnalité d'import automatique des bulletins CPS.
# Reste vide / commenté si tu veux fonctionner en saisie manuelle uniquement.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxx
